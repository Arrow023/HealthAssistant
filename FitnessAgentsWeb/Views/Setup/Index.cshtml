@{
    ViewData["Title"] = "Initial Setup";
    ViewData["AuthPage"] = true;
}

<div class="auth-layout">
    <div class="auth-form-side" style="flex: 1; overflow-y: auto; padding: 2rem;">
        <div style="max-width: 700px; width: 100%; margin: 0 auto;">
            <div style="margin-bottom: 2rem;">
                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                    <div style="width: 44px; height: 44px; border-radius: 12px; background: var(--primary); display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-heart-pulse" style="color: #fff; font-size: 1.2rem;"></i>
                    </div>
                    <span style="font-weight: 800; font-size: 1.4rem; color: var(--text);">FitnessAgents</span>
                </div>
                <h1 style="font-size: 1.75rem; font-weight: 800; margin: 0 0 0.5rem; color: var(--text);">Initial Setup</h1>
                <p style="color: var(--text-secondary); margin: 0;">Configure your AI fitness assistant. This only runs once on first launch.</p>
            </div>

            <form method="post" asp-controller="Setup" asp-action="Index">
                <!-- Admin Account -->
                <div class="card" style="margin-bottom: 1.25rem;">
                    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-shield-halved" style="color: var(--accent-red); margin-right: 0.5rem;"></i>Admin Account</h3>
                    <div class="grid-2" style="gap: 1rem;">
                        <div class="form-group">
                            <label class="form-label">Admin Email</label>
                            <input type="email" name="adminEmail" required placeholder="admin@example.com" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Admin Password</label>
                            <input type="password" name="adminPassword" required placeholder="Choose a secure password" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- AI Config -->
                <div class="card" style="margin-bottom: 1.25rem;">
                    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-brain" style="color: var(--primary); margin-right: 0.5rem;"></i>AI Agent Configuration</h3>
                    <div class="grid-2" style="gap: 1rem;">
                        <div class="form-group">
                            <label class="form-label">Model ID</label>
                            <input type="text" name="aiModel" required value="meta/llama-3.1-405b-instruct" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">API Key</label>
                            <input type="password" name="aiKey" required placeholder="nvapi-..." class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">API Endpoint</label>
                        <input type="text" name="aiEndpoint" required value="https://integrate.api.nvidia.com/v1" class="form-control" />
                    </div>
                </div>

                <!-- OCR Vision -->
                <div class="card" style="margin-bottom: 1.25rem;">
                    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-eye" style="color: var(--accent-purple); margin-right: 0.5rem;"></i>OCR Vision Configuration</h3>
                    <div class="grid-2" style="gap: 1rem;">
                        <div class="form-group">
                            <label class="form-label">OCR Model</label>
                            <input type="text" name="ocrModel" required value="meta/llama-3.2-90b-vision-instruct" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">OCR API Key</label>
                            <input type="password" name="ocrKey" required placeholder="nvapi-..." class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">OCR Endpoint</label>
                        <input type="text" name="ocrEndpoint" required value="https://integrate.api.nvidia.com/v1" class="form-control" />
                    </div>
                </div>

                <!-- SMTP -->
                <div class="card" style="margin-bottom: 1.25rem;">
                    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-envelope" style="color: var(--accent-orange); margin-right: 0.5rem;"></i>SMTP Email Delivery</h3>
                    <div class="grid-2" style="gap: 1rem;">
                        <div class="form-group">
                            <label class="form-label">SMTP Host</label>
                            <input type="text" name="smtpHost" required placeholder="smtp.gmail.com" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">SMTP Port</label>
                            <input type="number" name="smtpPort" required value="587" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">From Email</label>
                            <input type="email" name="fromEmail" required placeholder="fitnessAI@gmail.com" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">App Password</label>
                            <input type="password" name="smtpPassword" required placeholder="App-Specific Password" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Regional -->
                <div class="card" style="margin-bottom: 1.25rem;">
                    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-globe" style="color: var(--accent-green); margin-right: 0.5rem;"></i>Regional Settings</h3>
                    <div class="form-group">
                        <label class="form-label">Timezone</label>
                        <select name="timezone" class="form-control">
                            @foreach (var tz in FitnessAgentsWeb.Core.Helpers.TimezoneHelper.GetAllTimezones())
                            {
                                <option value="@tz" selected="@(tz == "India Standard Time")">@tz</option>
                            }
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn btn-block" style="padding: 0.85rem;">
                    <i class="fa-solid fa-rocket" style="margin-right: 0.5rem;"></i>Initialize FitnessAgents
                </button>
            </form>
        </div>
    </div>

    <div class="auth-illustration-side">
        <div style="text-align: center; max-width: 380px;">
            <i class="fa-solid fa-gears" style="font-size: 4rem; color: rgba(255,255,255,0.9); margin-bottom: 1.5rem;"></i>
            <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 0 0 0.75rem;">One-Time Setup</h2>
            <p style="color: rgba(255,255,255,0.8); font-size: 1.05rem; line-height: 1.6; margin: 0;">
                Connect your AI models, email service, and start generating personalized fitness plans in minutes.
            </p>
        </div>
    </div>
</div>
