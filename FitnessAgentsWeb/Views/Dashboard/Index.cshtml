@{
    ViewData["Title"] = "Dashboard";
}

<!-- TAB 1: OVERVIEW -->
<div id="tab-overview" class="tab-pane active">
    <!-- Personalized Greeting -->
    <div style="margin-bottom: 2rem;">
        <h2 class="section-title" style="margin-bottom: 0.2rem;">Welcome back, @(ViewBag.UserHealthContext?.FirstName ?? "Athlete")!</h2>
        <p class="section-subtitle">Your physiological profile and readiness for today.</p>
    </div>

    <!-- Top Metric Cards -->
    <div class="dashboard-grid" style="margin-bottom: 2rem;">
        <div class="metric-card" style="background: linear-gradient(135deg, #10b981, #059669); color: white;">
            <h3 style="color: rgba(255,255,255,0.8);">Steps</h3>
            <div class="value" style="color: white; -webkit-text-fill-color: white;">@(ViewBag.UserHealthContext?.VitalsSteps ?? "0") Steps</div>
            <div style="font-size: 0.85rem; margin-top: 0.5rem; opacity: 0.9;">Today's Activity</div>
        </div>
        
        <div class="metric-card" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white;">
            <h3 style="color: rgba(255,255,255,0.8);">Sleep</h3>
            <div class="value" style="color: white; -webkit-text-fill-color: white;">@(ViewBag.UserHealthContext?.VitalsSleepTotal ?? "--")</div>
            <div style="font-size: 0.85rem; margin-top: 0.5rem; opacity: 0.9;">Today's Total Sleep</div>
        </div>

        <div class="metric-card" style="background: linear-gradient(135deg, #ef4444, #dc2626); color: white;">
            <h3 style="color: rgba(255,255,255,0.8);">Calories</h3>
            <div class="value" style="color: white; -webkit-text-fill-color: white;">@(ViewBag.UserHealthContext?.VitalsCalories ?? "0 kcal")</div>
            <div style="font-size: 0.85rem; margin-top: 0.5rem; opacity: 0.9;">Active Calories Burn</div>
        </div>

        <div class="metric-card" style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white;">
            <h3 style="color: rgba(255,255,255,0.8);">Heart Rate (RHR)</h3>
            <div class="value" style="color: white; -webkit-text-fill-color: white;">@(ViewBag.UserHealthContext?.VitalsRhr ?? "--") Bpm</div>
            <div style="font-size: 0.85rem; margin-top: 0.5rem; opacity: 0.9;">India Time Zone (IST)</div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="form-grid">
        <!-- Detailed Sleep Curve Chart -->
        <div class="glass-panel" style="display: flex; flex-direction: column;">
            <h3 style="margin-top: 0; color: var(--text);">Sleep Stages Curve</h3>
            <div style="flex: 1; min-height: 250px;">
                <canvas id="sleepCurveChart"></canvas>
            </div>
        </div>
        
        <!-- Body Composition Doughnut -->
        <div class="glass-panel" style="display: flex; flex-direction: column;">
            <h3 style="margin-top: 0; color: var(--text);">Body Composition</h3>
            <div style="flex: 1; min-height: 250px;">
                <canvas id="bodyCompChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- TAB 2: DIET PLANNER -->
<div id="tab-diet" class="tab-pane">
    <div class="glass-panel">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 class="section-title" style="margin-bottom: 0;">Featured Diet Menu</h2>
                <p class="section-subtitle" style="margin-bottom: 0;">Daily macro-optimized recovery plan.</p>
            </div>
            <div style="display: flex; gap: 0.8rem;">
                <form method="post" action="/Dashboard/ResendDietPlan" style="margin: 0;">
                    <input type="hidden" name="userId" value="@ViewBag.UserId" />
                    <button type="submit" class="btn btn-secondary" style="padding: 0.6rem 1.2rem; font-size: 1rem;"><i class="fa-solid fa-envelope" style="margin-right:8px;"></i> Send via Email</button>
                </form>
                <form method="post" action="/Dashboard/TriggerPlanEmail" style="margin: 0;">
                    <input type="hidden" name="userId" value="@ViewBag.UserId" />
                    <button type="submit" class="btn" style="padding: 0.6rem 1.2rem; font-size: 1rem;" onclick="alert('Regenerating diet via AI...');"><i class="fa-solid fa-rotate-right" style="margin-right:8px;"></i> Regenerate Plan</button>
                </form>
            </div>
        </div>

        @if (ViewBag.DietData != null)
        {
            var diet = (FitnessAgentsWeb.Models.DietPlan)ViewBag.DietData;
            <div style="background: rgba(243, 244, 246, 0.5); padding: 1.5rem; border-radius: 16px; border: 1px solid var(--border);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 2px solid var(--border); padding-bottom: 1rem;">
                    <span style="font-weight: 800; font-size: 1.2rem; color: var(--text);">Daily Target: @diet.TotalCaloriesTarget kcal</span>
                    <span style="color: var(--text-muted); font-size: 0.9rem;"><i class="fa-solid fa-robot"></i> @diet.AiSummary</span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr; gap: 0.8rem;">
                    @{
                        var groupedMeals = diet.Meals.GroupBy(m => m.MealType);
                    }
                    @foreach(var group in groupedMeals)
                    {
                        <div style="margin-top: 0.5rem;">
                            <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--secondary); display: block; margin-bottom: 0.4rem; padding-left: 0.5rem;">@group.Key</span>
                            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                                @foreach(var meal in group)
                                {
                                    <div style="background: white; padding: 0.6rem 1.2rem; border-radius: 10px; box-shadow: var(--shadow-sm); display: flex; align-items: center; justify-content: space-between; border-left: 3px solid var(--secondary); flex-wrap: wrap; gap: 0.5rem;">
                                        <div style="flex: 1; min-width: 150px;">
                                            <span style="font-size: 1rem; font-weight: 700; color: var(--text); word-break: break-word;">@meal.FoodName</span>
                                            <span style="color: var(--text-muted); font-size: 0.85rem; margin-left: 0.4rem; display: inline-block;">(@meal.QuantityDescription)</span>
                                        </div>
                                        <div style="font-weight: 800; color: var(--primary); font-size: 0.95rem; white-space: nowrap;">
                                            @meal.Calories kcal
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        

        <!-- Diet History Section -->
        <div style="margin-top: 3rem;">
            <h3 class="section-title" style="font-size: 1.5rem; margin-bottom: 1rem;">Diet History</h3>
            <p class="section-subtitle">This week's nutritional tracking.</p>

            @if (ViewBag.HasDietHistory)
            {
                var dietHistory = (FitnessAgentsWeb.Models.WeeklyDietHistory)ViewBag.DietHistoryData;
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin-top: 1.5rem;">
                    @foreach (var dayPlan in dietHistory.PastDiets.OrderByDescending(x => x.Key))
                    {
                        <div class="glass-panel history-card" style="padding: 1.2rem; border: 1px solid var(--border); box-shadow: none; cursor: pointer; transition: transform 0.2s;" onclick="viewDietPlan('@dayPlan.Key')">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem;">
                                <span style="font-weight: 800; color: var(--secondary); text-transform: uppercase; font-size: 0.85rem;">@dayPlan.Key</span>
                                <span style="font-weight: 700; font-size: 0.9rem;">@dayPlan.Value.TotalCaloriesTarget kcal</span>
                            </div>
                            <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@dayPlan.Value.AiSummary</p>
                            
                            <div style="display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.8rem;">
                                @foreach (var m in dayPlan.Value.Meals.Take(2))
                                {
                                    <div style="display: flex; justify-content: space-between;">
                                        <span style="color: var(--text);">@m.FoodName</span>
                                        <span style="color: var(--text-muted);">@m.Calories kcal</span>
                                    </div>
                                }
                                @if (dayPlan.Value.Meals.Count > 2)
                                {
                                    <span style="color: var(--secondary); font-style: italic; font-size: 0.75rem;">+ @(dayPlan.Value.Meals.Count - 2) more meals...</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="background: rgba(0,0,0,0.03); padding: 2rem; border-radius: 12px; text-align: center; border: 1px dashed var(--border);">
                    <p style="color: var(--text-muted); font-size: 0.9rem;">No meal history for this week. Start today's plan!</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- TAB 3: EXERCISE LOG -->
<div id="tab-exercise" class="tab-pane">
    <div class="glass-panel" style="margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 class="section-title" style="margin-bottom: 0;">Exercise Log</h2>
                <p class="section-subtitle" style="margin-bottom: 0;">Weekly AI Orchestrated workout history.</p>
            </div>
            <form method="post" action="/Dashboard/TriggerPlanEmail">
                <input type="hidden" name="userId" value="@ViewBag.UserId" />
                <button type="submit" class="btn" onclick="alert('Your AI Coach is building your plan and will email it shortly!');">
                    <i class="fa-regular fa-paper-plane" style="margin-right:8px;"></i> Generate & Email New Plan
                </button>
            </form>
        </div>

        @if (ViewBag.HasHistory && ViewBag.HistoryData.PastWorkouts.Count > 0)
        {
            <div class="history-card-grid">
                @foreach (var workout in ViewBag.HistoryData.PastWorkouts)
                {
                    <div class="history-card">
                        <div>
                            <div class="day-name">@workout.Key</div>
                            <div class="plan-preview">@workout.Value</div>
                        </div>
                        <div class="history-card-actions">
                            <button class="btn btn-secondary btn-small" onclick="viewPlan('@workout.Key')">
                                <i class="fa-solid fa-eye"></i> View Plan
                            </button>
                            <form method="post" action="/Dashboard/ResendPlan" style="margin:0;">
                                <input type="hidden" name="userId" value="@ViewBag.UserId" />
                                <input type="hidden" name="dayOfWeek" value="@workout.Key" />
                                <button type="submit" class="btn btn-small" title="Resend to Email">
                                    <i class="fa-solid fa-envelope"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
                <i class="fa-solid fa-clipboard-list" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                <p>No workout records available for this week.</p>
            </div>
        }
    </div>
</div>

<!-- PLAN MODAL (Workout) -->
<div id="planModal" class="modal-overlay" onclick="if(event.target == this) closeModal('planModal')">
    <div class="modal-container">
        <div class="modal-header">
            <h2 id="modalTitle">Workout Plan</h2>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <form id="modalResendForm" method="post" action="/Dashboard/ResendPlan" style="margin:0;">
                    <input type="hidden" name="userId" value="@ViewBag.UserId" />
                    <input type="hidden" id="modalDayOfWeek" name="dayOfWeek" value="" />
                    <button type="submit" class="btn btn-small btn-secondary" title="Resend to Email">
                        <i class="fa-solid fa-envelope"></i> Resend Email
                    </button>
                </form>
                <button class="close-modal" onclick="closeModal('planModal')">&times;</button>
            </div>
        </div>
        <div class="modal-body">
            <div id="modalContent" class="plan-render-content">
                <!-- AI Content Injected Here -->
            </div>
        </div>
    </div>
</div>

<!-- DIET MODAL -->
<div id="dietModal" class="modal-overlay" onclick="if(event.target == this) closeModal('dietModal')">
    <div class="modal-container">
        <div class="modal-header">
            <h2 id="dietModalTitle">Nutrition Plan</h2>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <form method="post" action="/Dashboard/ResendDietPlan" style="margin:0;">
                    <input type="hidden" name="userId" value="@ViewBag.UserId" />
                    <input type="hidden" id="dietModalDayOfWeek" name="dayOfWeek" value="" />
                    <button type="submit" class="btn btn-small btn-secondary" title="Resend to Email">
                        <i class="fa-solid fa-envelope"></i> Resend Email
                    </button>
                </form>
                <button class="close-modal" onclick="closeModal('dietModal')">&times;</button>
            </div>
        </div>
        <div class="modal-body">
            <div id="dietModalContent" class="plan-render-content">
                <!-- Data Rendered via JS -->
            </div>
        </div>
    </div>
</div>

<script>
    // Store pre-rendered HTML for JS access
    const historyHtmlMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.HistoryHtml));
    const dietHistoryMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.DietHistoryData?.PastDiets ?? new Dictionary<string, FitnessAgentsWeb.Models.DietPlan>()));

    function viewPlan(day) {
        const title = document.getElementById('modalTitle');
        const content = document.getElementById('modalContent');
        const dayInput = document.getElementById('modalDayOfWeek');
        
        title.innerText = day + "'s Elite Workout Plan";
        content.innerHTML = historyHtmlMap[day] || "<p>No content available.</p>";
        dayInput.value = day;
        
        document.getElementById('planModal').style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevent scrolling
    }

    function viewDietPlan(day) {
        const plan = dietHistoryMap[day];
        if (!plan) return;

        const title = document.getElementById('dietModalTitle');
        const content = document.getElementById('dietModalContent');
        const dayInput = document.getElementById('dietModalDayOfWeek');
        
        title.innerText = day + "'s Elite Nutrition Plan";
        dayInput.value = day;

        // Simple render of the DietPlan object
        let html = `<div style="margin-bottom: 2rem; padding: 1.5rem; background: rgba(0,0,0,0.02); border-radius: 12px; border: 1px dashed var(--border);">
                        <div style="font-weight: 800; font-size: 1.2rem; color: var(--primary); margin-bottom: 0.5rem;">Daily Target: ${plan.total_calories_target} kcal</div>
                        <p style="color: var(--text-muted); font-style: italic; font-size: 0.95rem;">"${plan.ai_summary}"</p>
                    </div>`;

        // Group meals for the modal
        const mealsByGroup = {};
        plan.meals.forEach(m => {
            if (!mealsByGroup[m.meal_type]) mealsByGroup[m.meal_type] = [];
            mealsByGroup[m.meal_type].push(m);
        });

        for (const [group, items] of Object.entries(mealsByGroup)) {
            html += `<div style="margin-top: 1.5rem;">
                        <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--secondary); display: block; margin-bottom: 0.6rem;">${group}</span>
                        <div style="display: flex; flex-direction: column; gap: 0.6rem;">`;
            items.forEach(item => {
                html += `<div style="background: white; padding: 0.8rem 1.2rem; border-radius: 10px; border: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <strong style="color: var(--text);">${item.food_name}</strong>
                                <span style="color: var(--text-muted); margin-left: 0.5rem; font-size: 0.9rem;">(${item.quantity_description})</span>
                            </div>
                            <div style="font-weight: 800; color: var(--secondary);">${item.calories} kcal</div>
                         </div>`;
            });
            html += `</div></div>`;
        }

        content.innerHTML = html;
        document.getElementById('dietModal').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeModal(modalId) {
        document.getElementById(modalId).style.display = 'none';
        document.body.style.overflow = 'auto';
    }
</script>

<!-- TAB 4: PREFERENCES -->
<div id="tab-preferences" class="tab-pane">
    <div class="glass-panel" style="max-width: 600px; margin: 0 auto;">
        <h2 class="section-title">User Preferences</h2>
        <p class="section-subtitle" style="margin-bottom: 2rem;">Help your AI shape a better experience.</p>

        <form method="post" action="/Dashboard/UpdatePreferences">
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" name="firstName" value="@(ViewBag.UserProfile?.FirstName ?? "")" required />
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" name="lastName" value="@(ViewBag.UserProfile?.LastName ?? "")" required />
                </div>
            </div>

            <div class="form-group">
                <label>Notification Email</label>
                <input type="email" name="email" value="@(ViewBag.UserProfile?.Email ?? "")" required />
            </div>

            <div class="form-group">
                <label>Daily AI Notification Time (HH:MM)</label>
                <input type="time" name="notificationTime" value="@(ViewBag.UserProfile?.NotificationTime ?? "08:00")" required />
            </div>

            <div class="form-group">
                <label>New Password (Leave blank to keep current)</label>
                <input type="password" name="newPassword" placeholder="••••••••" />
            </div>

            <div class="form-group">
                <label>How are you feeling today?</label>
                <textarea name="preferences" rows="4" style="width: 100%; padding: 1rem; border-radius: 10px; border: 2px solid var(--border); font-family: inherit; font-size: 1rem; resize: vertical;" placeholder="E.g., No injuries, but my low back is stiff.">@(ViewBag.UserProfile?.Preferences ?? "")</textarea>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">This directly informs the <code>ConditionsBrief</code> for the AI Prompt.</p>
            </div>

            <div class="form-group">
                <label>Food Preferences / Restrictions</label>
                <textarea name="foodPreferences" rows="4" style="width: 100%; padding: 1rem; border-radius: 10px; border: 2px solid var(--border); font-family: inherit; font-size: 1rem; resize: vertical;" placeholder="E.g., Vegetarian, doesn't like soya chunks but can eat eggs.">@(ViewBag.UserProfile?.FoodPreferences ?? "")</textarea>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">This informs the AI Sports Nutritionist for meal planning.</p>
            </div>

            <div style="margin-top: 2rem; border-top: 1px dashed var(--border); padding-top: 1.5rem;">
                <h3 style="margin-bottom: 1rem; color: var(--text); font-size: 1.1rem;">Weekly Workout Schedule</h3>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">Configure your target muscle groups for each day.</p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">
                    @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
                    {
                        var scheduleVal = "";
                        if (ViewBag.UserProfile?.WorkoutSchedule != null)
                        {
                            ((System.Collections.Generic.Dictionary<string, string>)ViewBag.UserProfile.WorkoutSchedule).TryGetValue(day, out scheduleVal);
                        }
                        <div class="form-group">
                            <label style="font-size: 0.8rem; font-weight: 700;">@day</label>
                            <input type="text" name="schedule@(day)" value="@scheduleVal" placeholder="e.g. Chest and Triceps" />
                        </div>
                    }
                </div>
            </div>

            <div style="margin-top: 2rem; border-top: 1px dashed var(--border); padding-top: 1.5rem;">
                <h3 style="margin-bottom: 1rem; color: var(--text); font-size: 1.1rem;">Webhook Security</h3>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label style="font-size: 0.8rem;">Webhook Header Key</label>
                        <input type="text" name="webhookHeaderKey" value="@(ViewBag.UserProfile?.WebhookHeaderKey ?? "")" placeholder="e.g. x-api-key" />
                    </div>
                    <div class="form-group">
                        <label style="font-size: 0.8rem;">Webhook Header Value</label>
                        <input type="password" name="webhookHeaderValue" value="@(ViewBag.UserProfile?.WebhookHeaderValue ?? "")" placeholder="••••••••" />
                    </div>
                </div>
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">Require a custom header for your private webhook. Leave blank to disable restriction.</p>
            </div>

            <button type="submit" class="btn" style="width: 100%; margin-top: 2rem;">Save All Preferences</button>
        </form>

        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px dashed var(--border);">
            <h3 style="margin-top: 0; color: var(--text); font-size: 1.1rem;">Integrations & Systems</h3>
            
            <div style="background: #f9fafb; padding: 1.5rem; border-radius: 12px; border: 1px dashed var(--primary); margin-top: 1rem;">
                <span style="color: var(--primary); font-size: 0.85rem; font-weight: 800; text-transform: uppercase;">Private Webhook URL</span>
                <div style="font-family: monospace; color: var(--text); font-size: 1rem; margin-top: 0.5rem; word-break: break-all; font-weight: 600;">
                    @ViewBag.WebhookUrl
                </div>
            </div>

            <form method="post" action="/Dashboard/UploadInBody" enctype="multipart/form-data" style="margin-top: 2rem;">
                <label>Update Biological Scan (InBody)</label>
                <input type="file" name="inBodyImage" accept="image/*" style="margin-bottom: 1rem; background: white; padding: 0.5rem; border-radius: 8px;" />
                <input type="hidden" name="userId" value="@ViewBag.UserId" />
                <button class="btn btn-secondary" type="submit" style="width: 100%;"><i class="fa-solid fa-camera"></i> Execute OCR Vision Run</button>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // --- Sleep Curve Chart ---
        const ctxSleepCurve = document.getElementById('sleepCurveChart');
        if (ctxSleepCurve) {
            const ctx = ctxSleepCurve.getContext('2d');
            
            // Build Sleep Data from raw HealthConnect JSON mapped to the sleep model
            const sleepLabels = [];
            const sleepDataPoints = [];
            
            @if (ViewBag.HealthData != null && ViewBag.HealthData.Sleep != null)
            {
                <text>
                // Wake(1)=4, REM(6)=3, Light(4)=2, Deep(5)=1
                const stageMap = { '1': 4, '4': 2, '5': 1, '6': 3 };
                
                // Filter and Sort Stages chronologically
                @{
                    var istZoneGraph = TimeZoneInfo.FindSystemTimeZoneById("India Standard Time");
                    var nowIstGraph = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, istZoneGraph).Date;
                    var windowStart = nowIstGraph.AddHours(-12);
                    var windowEnd = nowIstGraph.AddHours(12);

                    var allStagesRaw = ViewBag.HealthData.Sleep as List<FitnessAgentsWeb.Models.SleepSession>;
                    if (allStagesRaw != null)
                    {
                        var allStages = allStagesRaw
                            .SelectMany(s => s.Stages)
                            .Where(st => {
                                var stIst = TimeZoneInfo.ConvertTimeFromUtc(st.StartTime, istZoneGraph);
                                return stIst >= windowStart && stIst < windowEnd;
                            })
                            .OrderBy(st => st.StartTime)
                            .ToList();

                        foreach(var stage in allStages)
                        {
                            var istTime = TimeZoneInfo.ConvertTimeFromUtc(stage.StartTime, istZoneGraph);
                            @:sleepLabels.push('@istTime.ToString("HH:mm")');
                            @:sleepDataPoints.push(stageMap['@stage.Stage'] || 2);
                        }
                    }
                }
                </text>
            }

            if (sleepDataPoints.length === 0) {
                // Dummy fallback if no payload structure matches
                sleepLabels.push('22:00', '23:00', '00:00', '02:00', '04:00', '06:00');
                sleepDataPoints.push(4, 2, 1, 3, 2, 4);
            }

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: sleepLabels,
                    datasets: [{
                        label: 'Sleep Stages',
                        data: sleepDataPoints,
                        borderColor: 'rgba(59, 130, 246, 1)',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        borderWidth: 3,
                        pointBackgroundColor: 'rgba(239, 68, 68, 1)',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        fill: true,
                        tension: 0.4,
                        stepped: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { 
                            min: 0,
                            max: 5,
                            ticks: {
                                callback: function(value) {
                                    if(value === 4) return 'Awake';
                                    if(value === 3) return 'REM';
                                    if(value === 2) return 'Light';
                                    if(value === 1) return 'Deep';
                                    return '';
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        // --- Body Composition Doughnut ---
        const ctxBody = document.getElementById('bodyCompChart');
        if (ctxBody) {
            let bf = 0; let smm = 0;
            @{
                double bfParsed = 0;
                double smmParsed = 0;
                if (ViewBag.UserHealthContext != null)
                {
                    double.TryParse(ViewBag.UserHealthContext.InBodyBf, out bfParsed);
                    double.TryParse(ViewBag.UserHealthContext.InBodySmm, out smmParsed);
                }
            }
            bf = @bfParsed;
            smm = @smmParsed;

            new Chart(ctxBody.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Body Fat %', 'Muscle Mass (kg)', 'Remaining'],
                    datasets: [{
                        data: [bf, smm, Math.max(0, 100 - (bf + smm))],
                        backgroundColor: [ '#ef4444', '#3b82f6', '#e5e7eb' ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        }
    });
</script>
