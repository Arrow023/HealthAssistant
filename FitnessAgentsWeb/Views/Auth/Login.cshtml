@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["AuthPage"] = true;
}

<div class="auth-layout">
    <!-- Animated Background -->
    <div class="bg-canvas" aria-hidden="true" style="position: fixed;">
        <div class="bg-orb bg-orb--1"></div>
        <div class="bg-orb bg-orb--2"></div>
        <div class="bg-orb bg-orb--3"></div>
    </div>

    <!-- Left: Form -->
    <div class="auth-form-side">
        <div class="auth-form-container fade-up">
            <div class="auth-header">
                <div class="auth-brand">
                    <div class="auth-brand-icon">
                        <img src="~/images/favicon-light.svg" alt="FitnessAgents" class="show-light" />
                        <img src="~/images/favicon-dark.svg" alt="FitnessAgents" class="show-dark" />
                    </div>
                    <span class="auth-brand-name">FitnessAgents</span>
                </div>
                <h1 class="auth-title">Welcome back</h1>
                <p class="auth-subtitle">Sign in to access your AI-powered fitness dashboard.</p>
            </div>

            @if (Model?.ErrorMessage != null)
            {
                <div class="auth-error">
                    <i class="fa-solid fa-circle-exclamation"></i>@Model.ErrorMessage
                </div>
            }

            <form method="post" asp-controller="Auth" asp-action="Login">
                <div class="form-group">
                    <label class="form-label">Username or Email</label>
                    <input type="text" name="email" required placeholder="admin@example.com or user_id" class="form-control" autofocus />
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" required placeholder="••••••••" class="form-control" />
                </div>
                <button type="submit" class="btn btn-block btn-lg auth-submit-btn">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>Sign In
                </button>
            </form>

            <p class="auth-footer">
                Open-source AI Fitness Assistant &mdash; <a href="https://github.com">View on GitHub</a>
            </p>
        </div>
    </div>

    <!-- Right: Dark atmospheric illustration -->
    <div class="auth-illustration-side">
        <!-- Grid pattern overlay -->
        <svg class="auth-grid-pattern" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <defs>
                <pattern id="authGrid" width="40" height="40" patternUnits="userSpaceOnUse">
                    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(52,211,153,0.06)" stroke-width="0.5"/>
                </pattern>
                <radialGradient id="authFade" cx="50%" cy="50%" r="60%">
                    <stop offset="0%" stop-color="white"/>
                    <stop offset="100%" stop-color="black"/>
                </radialGradient>
                <mask id="authMask">
                    <rect width="400" height="400" fill="url(#authFade)"/>
                </mask>
            </defs>
            <rect width="400" height="400" fill="url(#authGrid)" mask="url(#authMask)"/>
        </svg>

        <div class="auth-illustration-content">
            <div class="auth-logo-ring">
                <img src="~/images/logo-light.svg" alt="FitnessAgents" class="auth-logo-img show-light" />
                <img src="~/images/logo-dark.svg" alt="FitnessAgents" class="auth-logo-img show-dark" />
            </div>
            <h2 class="auth-hero-title">Your AI Fitness Coach</h2>
            <p class="auth-hero-text">
                Personalized workout and diet plans generated daily using your real health data and body composition.
            </p>
            <div class="auth-features">
                <div class="auth-feature-item">
                    <div class="auth-feature-icon"><i class="fa-solid fa-brain"></i></div>
                    <span>AI Powered</span>
                </div>
                <div class="auth-feature-item">
                    <div class="auth-feature-icon"><i class="fa-solid fa-chart-line"></i></div>
                    <span>Data Driven</span>
                </div>
                <div class="auth-feature-item">
                    <div class="auth-feature-icon"><i class="fa-solid fa-lock-open"></i></div>
                    <span>Open Source</span>
                </div>
            </div>
        </div>
    </div>
</div>
