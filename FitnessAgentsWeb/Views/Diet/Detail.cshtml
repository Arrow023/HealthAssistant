@model DietDetailViewModel
@{
    ViewData["Title"] = $"{Model.DayOfWeek}'s Diet";
}

<div class="page-header fade-up">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 class="page-title">@Model.DayOfWeek's Nutrition</h1>
            <p class="page-subtitle">Macro-optimized recovery diet plan.</p>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <form method="post" asp-controller="Diet" asp-action="ResendEmail" style="margin: 0;">
                <input type="hidden" name="userId" value="@Model.UserId" />
                <input type="hidden" name="dayOfWeek" value="@Model.DayOfWeek" />
                <button type="submit" class="btn btn-outline btn-sm">
                    <i class="fa-solid fa-envelope"></i> Email Plan
                </button>
            </form>
            <a href="/Diet?userId=@Model.UserId" class="btn btn-sm btn-outline">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>
        </div>
    </div>
</div>

<div class="grid-2 fade-up" style="align-items: start;">
    <!-- Main Content -->
    <div>
        <!-- Macros Header -->
        <div class="macros-bar" style="margin-bottom: 1.5rem;">
            <div class="macro-item">
                <span class="macro-item-value">@Model.Diet.TotalCaloriesTarget</span>
                <span class="macro-item-unit">cal</span>
                <div class="macro-item-label">Calories</div>
            </div>
            <div class="macro-item">
                <span class="macro-item-value">@Model.Diet.Meals.Count</span>
                <span class="macro-item-unit">meals</span>
                <div class="macro-item-label">Meals</div>
            </div>
            <div class="macro-item">
                @{
                    var mealTypes = Model.Diet.Meals.Select(m => m.MealType).Distinct().Count();
                }
                <span class="macro-item-value">@mealTypes</span>
                <span class="macro-item-unit">types</span>
                <div class="macro-item-label">Categories</div>
            </div>
            <div class="macro-item">
                <span class="macro-item-value">@Model.Diet.PlanDate.ToString("dd")</span>
                <span class="macro-item-unit">@Model.Diet.PlanDate.ToString("MMM")</span>
                <div class="macro-item-label">Date</div>
            </div>
        </div>

        <!-- AI Summary -->
        <div class="card" style="margin-bottom: 1.25rem; background: var(--primary-subtle); border-color: var(--primary);">
            <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <i class="fa-solid fa-robot" style="color: var(--primary); font-size: 1.1rem; margin-top: 0.2rem;"></i>
                <div>
                    <div style="font-weight: 700; color: var(--text); margin-bottom: 0.25rem;">AI Nutritionist Summary</div>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 0.95rem; line-height: 1.5;">@Model.Diet.AiSummary</p>
                </div>
            </div>
        </div>

        <!-- Meals by Group -->
        @{
            var grouped = Model.Diet.Meals.GroupBy(m => m.MealType);
        }
        @foreach (var group in grouped)
        {
            <div class="meal-group-label">@group.Key</div>
            @foreach (var meal in group)
            {
                <div class="meal-row">
                    <div>
                        <span class="meal-row-name">@meal.FoodName</span>
                        <span class="meal-row-qty">(@meal.QuantityDescription)</span>
                    </div>
                    <span class="meal-row-kcal">@meal.Calories kcal</span>
                </div>
            }
        }
    </div>

    <!-- Sidebar: Nutrition Facts -->
    <div>
        <div class="nutrition-facts" style="position: sticky; top: 80px;">
            <h3>Nutrition Summary</h3>

            <div class="nutrition-row">
                <span class="nutrition-row-label">Total Calories</span>
                <span class="nutrition-row-value">@Model.Diet.TotalCaloriesTarget kcal</span>
            </div>
            <div class="nutrition-row">
                <span class="nutrition-row-label">Total Items</span>
                <span class="nutrition-row-value">@Model.Diet.Meals.Count</span>
            </div>
            <div class="nutrition-row">
                <span class="nutrition-row-label">Plan Date</span>
                <span class="nutrition-row-value">@Model.Diet.PlanDate.ToString("ddd, MMM d")</span>
            </div>

            <hr class="section-divider" />

            <h3>Calories by Meal</h3>
            @foreach (var group in grouped)
            {
                var groupTotal = group.Sum(m => m.Calories);
                <div class="nutrition-row">
                    <span class="nutrition-row-label">@group.Key</span>
                    <span class="nutrition-row-value">@groupTotal kcal</span>
                </div>
            }

            <hr class="section-divider" />

            <div style="text-align: center; padding-top: 0.5rem;">
                <form method="post" asp-controller="Diet" asp-action="ResendEmail">
                    <input type="hidden" name="userId" value="@Model.UserId" />
                    <input type="hidden" name="dayOfWeek" value="@Model.DayOfWeek" />
                    <button type="submit" class="btn btn-block">
                        <i class="fa-solid fa-paper-plane"></i> Email This Plan
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
