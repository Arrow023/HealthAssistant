@model PlanFeedbackViewModel
@{
    ViewData["Title"] = $"Rate {Model.DayOfWeek}'s Workout";
}

<div class="page-header fade-up">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 class="page-title">Rate @Model.DayOfWeek's Workout</h1>
            <p class="page-subtitle">Your feedback helps the AI create better plans over time.</p>
        </div>
        <a href="/Workout/Detail?userId=@Model.UserId&day=@Model.DayOfWeek" class="btn btn-sm btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Back to Plan
        </a>
    </div>
</div>

@if (Model.ExistingFeedback is not null)
{
    <div class="card fade-up" style="margin-bottom: 1.5rem; background: var(--primary-subtle); border-color: var(--primary);">
        <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
            <i class="fa-solid fa-check-circle" style="color: var(--primary); font-size: 1.1rem; margin-top: 0.2rem;"></i>
            <div>
                <div style="font-weight: 700; margin-bottom: 0.25rem;">You already rated this plan</div>
                <p style="margin: 0; color: var(--text-secondary); font-size: 0.95rem;">
                    Rating: @Model.ExistingFeedback.Rating/5 &bull; 
                    Difficulty: @Model.ExistingFeedback.Difficulty
                    @if (!string.IsNullOrEmpty(Model.ExistingFeedback.Note))
                    {
                        <text>&bull; "@Model.ExistingFeedback.Note"</text>
                    }
                </p>
            </div>
        </div>
    </div>
}

<form method="post" asp-controller="Workout" asp-action="SubmitFeedback">
    <input type="hidden" name="UserId" value="@Model.UserId" />
    <input type="hidden" name="DayOfWeek" value="@Model.DayOfWeek" />
    <input type="hidden" name="PlanType" value="workout" />

    <div class="grid-2 fade-up" style="align-items: start;">
        <div>
            <!-- Rating -->
            <div class="card" style="margin-bottom: 1.25rem;">
                <h3 style="margin: 0 0 1rem; font-weight: 700;">
                    <i class="fa-solid fa-star" style="color: var(--accent-orange); margin-right: 0.5rem;"></i>Overall Rating
                </h3>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var val = i;
                        var isSelected = Model.ExistingFeedback?.Rating == val;
                        <label style="cursor: pointer;">
                            <input type="radio" name="Rating" value="@val" required
                                   style="display: none;" @(isSelected ? "checked" : "") />
                            <span class="rating-btn" data-value="@val"
                                  style="display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 12px; border: 2px solid var(--border); font-size: 1.1rem; font-weight: 700; transition: all .15s;">
                                @val<i class="fa-solid fa-star" style="font-size: 0.7rem; margin-left: 3px; color: var(--accent-orange);"></i>
                            </span>
                        </label>
                    }
                </div>
            </div>

            <!-- Difficulty -->
            <div class="card" style="margin-bottom: 1.25rem;">
                <h3 style="margin: 0 0 1rem; font-weight: 700;">
                    <i class="fa-solid fa-gauge-high" style="color: var(--accent-purple); margin-right: 0.5rem;"></i>Difficulty
                </h3>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    @{
                        var difficulties = new[] { ("too-easy", "Too Easy", "fa-face-meh"), ("just-right", "Just Right", "fa-face-smile"), ("too-hard", "Too Hard", "fa-face-tired") };
                    }
                    @foreach (var (value, label, icon) in difficulties)
                    {
                        var isSelected = (Model.ExistingFeedback?.Difficulty ?? "just-right") == value;
                        <label style="cursor: pointer; flex: 1;">
                            <input type="radio" name="Difficulty" value="@value" style="display: none;" @(isSelected ? "checked" : "") />
                            <span class="difficulty-btn" style="display: flex; flex-direction: column; align-items: center; gap: 0.4rem; padding: 0.75rem; border-radius: 12px; border: 2px solid var(--border); transition: all .15s; text-align: center;">
                                <i class="fa-solid @icon" style="font-size: 1.3rem;"></i>
                                <span style="font-size: 0.85rem; font-weight: 600;">@label</span>
                            </span>
                        </label>
                    }
                </div>
            </div>
        </div>

        <div>
            <!-- Skipped Items -->
            <div class="card" style="margin-bottom: 1.25rem;">
                <h3 style="margin: 0 0 1rem; font-weight: 700;">
                    <i class="fa-solid fa-forward" style="color: var(--accent-red); margin-right: 0.5rem;"></i>Skipped Exercises
                </h3>
                <div class="form-group">
                    <label class="form-label">Comma-separated exercise names you skipped</label>
                    <div class="field-hint">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>Use the <strong>exact exercise names</strong> from your plan, separated by commas. The AI will learn to avoid or replace these in future plans. Leave blank if you completed everything.</span>
                    </div>
                    <input type="text" name="SkippedItems"
                           value="@(Model.ExistingFeedback?.SkippedItems is not null ? string.Join(", ", Model.ExistingFeedback.SkippedItems) : "")"
                           placeholder="e.g. Face Pulls, Overhead Press"
                           class="form-control" />
                </div>
            </div>

            <!-- Notes -->
            <div class="card" style="margin-bottom: 1.25rem;">
                <h3 style="margin: 0 0 1rem; font-weight: 700;">
                    <i class="fa-solid fa-comment" style="color: var(--accent-green); margin-right: 0.5rem;"></i>Notes
                </h3>
                <div class="form-group">
                    <label class="form-label">Any thoughts for the AI coach?</label>
                    <div class="field-hint">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>Tell the AI what worked and what didn't — <code>too much volume</code> <code>loved the supersets</code> <code>more core work</code> <code>felt rushed</code>. The AI remembers this for <strong>all future plans</strong>.</span>
                    </div>
                    <textarea name="Note" rows="3" class="form-control"
                              placeholder="e.g. Loved the supersets! More core work next time.">@Model.ExistingFeedback?.Note</textarea>
                </div>
            </div>
        </div>
    </div>

    <div style="margin-top: 1rem; display: flex; justify-content: flex-end; gap: 0.75rem;">
        <a href="/Workout/Detail?userId=@Model.UserId&day=@Model.DayOfWeek" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn">
            <i class="fa-solid fa-paper-plane"></i> Submit Feedback
        </button>
    </div>
</form>

<style>
    input[type="radio"]:checked + .rating-btn {
        background: var(--primary-gradient);
        color: #fff;
        border-color: var(--primary);
        box-shadow: 0 4px 16px var(--primary-glow);
        transform: scale(1.08);
    }
    input[type="radio"]:checked + .rating-btn i { color: #fff !important; }
    input[type="radio"]:checked + .difficulty-btn {
        background: var(--primary-subtle);
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: 0 0 12px var(--primary-glow);
    }
    .rating-btn:hover, .difficulty-btn:hover {
        border-color: var(--primary);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px var(--primary-glow);
    }
    .rating-btn, .difficulty-btn {
        transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }
</style>
