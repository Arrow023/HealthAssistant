@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="page-header fade-up">
    <h1 class="page-title">My Profile</h1>
    <p class="page-subtitle">Manage your personal info, preferences, and workout schedule.</p>
</div>

<form method="post" asp-controller="Profile" asp-action="UpdatePreferences">
    <input type="hidden" name="userId" value="@Model.UserId" />

    <div class="grid-2 fade-up" style="align-items: start;">
        <!-- Left Column -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <!-- Personal Info -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-user" style="color: var(--primary); margin-right: 0.5rem;"></i>Personal Information</h3>
                <div class="grid-2" style="gap: 1rem;">
                    <div class="form-group">
                        <label class="form-label">First Name</label>
                        <input type="text" name="firstName" value="@Model.Profile?.FirstName" class="form-control" placeholder="First name" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last Name</label>
                        <input type="text" name="lastName" value="@Model.Profile?.LastName" class="form-control" placeholder="Last name" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" value="@Model.Profile?.Email" class="form-control" placeholder="you@example.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">New Password <span style="color: var(--text-secondary); font-weight: 400;">(leave blank to keep current)</span></label>
                    <input type="password" name="newPassword" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                </div>
            </div>

            <!-- Preferences -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-sliders" style="color: var(--accent-orange); margin-right: 0.5rem;"></i>AI Preferences</h3>
                <div class="form-group">
                    <label class="form-label">Health Conditions / Injuries</label>
                    <div class="field-hint field-hint--warn">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>Be specific — the AI uses this to <strong>avoid risky exercises</strong>. Include: injury name, which side, recovery stage, doctor's restrictions. E.g. <code>ACL tear, right knee, 3 months post-op, no heavy squats</code></span>
                    </div>
                    <textarea name="preferences" rows="3" class="form-control" placeholder="e.g. Recovering from knee surgery…">@Model.Profile?.Preferences</textarea>
                    <small style="color: var(--text-secondary);">This is sent to the AI when generating your personalised workout plans.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Food Preferences / Restrictions <span style="color: var(--text-secondary); font-weight: 400;">(soft — general notes)</span></label>
                    <div class="field-hint">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>These are <strong>soft guidelines</strong> — the AI tries to honor them but won't treat them as hard rules. Use for timing, portion size, or flavor preferences. For strict exclusions, use the <strong>Dietary Constraints</strong> section below instead.</span>
                    </div>
                    <textarea name="foodPreferences" rows="2" class="form-control" placeholder="e.g. I prefer lighter meals on fasting days, I like spicy food…">@Model.Profile?.FoodPreferences</textarea>
                    <small style="color: var(--text-secondary);">Soft preferences the AI will try to follow.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Notification Time</label>
                    <input type="time" name="notificationTime" value="@Model.Profile?.NotificationTime" class="form-control" style="max-width: 200px;" />
                </div>
            </div>

            <!-- Hard Dietary Constraints -->
            <div class="card">
                <h3 style="margin: 0 0 0.5rem; font-weight: 700;"><i class="fa-solid fa-ban" style="color: var(--accent-red, #ef4444); margin-right: 0.5rem;"></i>Dietary Constraints</h3>
                <p style="color: var(--text-secondary); margin: 0 0 0.75rem; font-size: 0.85rem;">These are <strong>hard rules</strong> — the AI will never violate them.</p>
                <div class="field-hint field-hint--warn">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span><strong>Hard constraints vs Soft preferences:</strong> Foods added here are <strong>permanently blocked</strong> — the AI will never suggest them. If you just want less of something (not zero), put it in the "Food Preferences" text box above instead.</span>
                </div>

                <div class="form-group">
                    <label class="form-label">Excluded Foods <span style="color: var(--accent-red, #ef4444); font-weight: 400;">(never include)</span></label>
                    <div class="tag-input-wrapper" id="excludedFoodsWrapper">
                        <div class="tag-pills" id="excludedFoodsPills"></div>
                        <input type="text" class="tag-input" id="excludedFoodsInput" placeholder="Type a food & press Enter…" />
                    </div>
                    <input type="hidden" name="excludedFoods" id="excludedFoodsHidden" value="@(Model.Profile?.ExcludedFoods != null ? string.Join(",", Model.Profile.ExcludedFoods) : "")" />
                    <small style="color: var(--text-secondary);">e.g. paneer, soya, broccoli, olive oil</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Cuisine Style</label>
                    <select name="cuisineStyle" class="form-control" style="max-width: 300px;">
                        @{
                            var cuisines = new[] { "", "Rajasthani", "Punjabi", "South Indian", "Bengali", "Gujarati", "Maharashtrian", "Hyderabadi", "Kerala", "Kashmiri", "Goan", "North Indian General", "Continental", "Mediterranean", "Other" };
                            var currentCuisine = Model.Profile?.CuisineStyle ?? "";
                        }
                        @foreach (var c in cuisines)
                        {
                            <option value="@c" selected="@(c == currentCuisine)">@(string.IsNullOrEmpty(c) ? "— Select cuisine style —" : c)</option>
                        }
                    </select>
                    <small style="color: var(--text-secondary);">The AI will use culturally authentic recipes from this cuisine.</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Preferred Cooking Oils</label>
                    <div class="tag-input-wrapper" id="cookingOilsWrapper">
                        <div class="tag-pills" id="cookingOilsPills"></div>
                        <input type="text" class="tag-input" id="cookingOilsInput" placeholder="Type an oil & press Enter…" />
                    </div>
                    <input type="hidden" name="cookingOils" id="cookingOilsHidden" value="@(Model.Profile?.CookingOils != null ? string.Join(",", Model.Profile.CookingOils) : "")" />
                    <small style="color: var(--text-secondary);">e.g. mustard oil, desi ghee, coconut oil</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Staple Grains</label>
                    <div class="tag-input-wrapper" id="stapleGrainsWrapper">
                        <div class="tag-pills" id="stapleGrainsPills"></div>
                        <input type="text" class="tag-input" id="stapleGrainsInput" placeholder="Type a grain & press Enter…" />
                    </div>
                    <input type="hidden" name="stapleGrains" id="stapleGrainsHidden" value="@(Model.Profile?.StapleGrains != null ? string.Join(",", Model.Profile.StapleGrains) : "")" />
                    <small style="color: var(--text-secondary);">e.g. bajra, wheat, jowar, rice</small>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <!-- Weekly Schedule -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-calendar-week" style="color: var(--accent-green); margin-right: 0.5rem;"></i>Weekly Schedule</h3>
                <p style="color: var(--text-secondary); margin: 0 0 0.75rem; font-size: 0.9rem;">Define the focus area for each day. The AI will generate workout plans based on this schedule.</p>
                <div class="field-hint">
                    <i class="fa-solid fa-circle-info"></i>
                    <span>Examples: <code>Chest + Triceps</code> <code>Pull Day</code> <code>Legs</code> <code>Cardio + Core</code> <code>HIIT</code> <code>Active Recovery</code> <code>Rest Day</code></span>
                </div>

                @{
                    string[] days = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
                    string[] icons = { "fa-dumbbell", "fa-heart-pulse", "fa-person-running", "fa-fire", "fa-spa", "fa-bolt", "fa-bed" };
                }
                @for (int i = 0; i < days.Length; i++)
                {
                    var day = days[i];
                    var current = Model.Profile?.WorkoutSchedule.GetValueOrDefault(day, "Rest Day") ?? "Rest Day";
                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                        <i class="fa-solid @icons[i]" style="width: 20px; text-align: center; color: var(--primary); font-size: 0.9rem;"></i>
                        <span style="width: 90px; font-weight: 600; font-size: 0.9rem;">@day</span>
                        <input type="text" name="schedule@(day)" value="@current" class="form-control" style="flex: 1;" />
                    </div>
                }
            </div>

            <!-- Webhook Config -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-link" style="color: var(--accent-purple); margin-right: 0.5rem;"></i>Webhook Integration</h3>
                <div class="form-group">
                    <label class="form-label">Webhook URL</label>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" id="webhookUrl" value="@Model.WebhookUrl" class="form-control" readonly style="flex: 1; font-family: monospace; font-size: 0.85rem;" />
                        <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('webhookUrl').value)" class="btn btn-outline btn-sm" title="Copy">
                            <i class="fa-solid fa-copy"></i>
                        </button>
                    </div>
                    <small style="color: var(--text-secondary);">Use this URL in automation tools (e.g. Health Connect, Tasker) to trigger workout generation.</small>
                </div>
                <div class="grid-2" style="gap: 1rem;">
                    <div class="form-group">
                        <label class="form-label">Auth Header Key</label>
                        <input type="text" name="webhookHeaderKey" value="@Model.Profile?.WebhookHeaderKey" class="form-control" placeholder="X-Api-Key" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Auth Header Value</label>
                        <input type="password" name="webhookHeaderValue" value="@Model.Profile?.WebhookHeaderValue" class="form-control" placeholder="Secret value" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end;" class="fade-up">
        <button type="submit" class="btn">
            <i class="fa-solid fa-check"></i> Save Changes
        </button>
    </div>
</form>

<!-- InBody Upload – separate form for file upload -->
<div class="card fade-up" style="margin-top: 1.5rem;">
    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-camera" style="color: var(--accent-pink); margin-right: 0.5rem;"></i>InBody Scan Upload</h3>
    <p style="color: var(--text-secondary); margin: 0 0 1rem; font-size: 0.9rem;">Upload an InBody scan image. Our AI will extract your body composition metrics automatically using OCR.</p>
    <form method="post" asp-controller="Profile" asp-action="UploadInBody" enctype="multipart/form-data">
        <input type="hidden" name="userId" value="@Model.UserId" />
        <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
            <label for="inBodyFileInput" class="inbody-file-label">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                <span id="inBodyFileName">Choose a scan image…</span>
            </label>
            <input type="file" id="inBodyFileInput" name="inBodyImage" accept="image/*" required
                   style="display: none;"
                   onchange="handleInBodyFileChange(this)" />
            <button type="submit" id="inBodySubmitBtn" class="btn btn-outline" disabled
                    style="opacity: 0.45; pointer-events: none; transition: opacity 0.25s, pointer-events 0s;">
                <i class="fa-solid fa-upload"></i> Analyse Scan
            </button>
        </div>
    </form>
</div>

@section Scripts {
<style>
    /* InBody file picker */
    .inbody-file-label {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 1.1rem;
        border: 1.5px dashed var(--border);
        border-radius: var(--radius, 0.5rem);
        background: var(--card-bg, #fff);
        color: var(--text-secondary);
        font-size: 0.88rem;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.2s;
        flex: 1;
        min-width: 220px;
    }
    .inbody-file-label:hover {
        border-color: var(--accent-pink);
        color: var(--accent-pink);
        background: var(--accent-pink-bg, rgba(236, 72, 153, 0.06));
        box-shadow: 0 0 12px rgba(236, 72, 153, 0.10);
    }
    .inbody-file-label i {
        font-size: 1.05rem;
    }
    .inbody-file-label.has-file {
        border-style: solid;
        border-color: var(--accent-pink);
        color: var(--text);
        background: var(--accent-pink-bg, rgba(236, 72, 153, 0.06));
    }
    .tag-input-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        padding: 0.5rem;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        min-height: 44px;
        cursor: text;
        transition: border-color 0.2s;
    }
    .tag-input-wrapper:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.15);
    }
    .tag-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }
    .tag-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.6rem;
        background: var(--primary);
        color: #fff;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 500;
        white-space: nowrap;
        animation: tagPop 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .tag-pill[data-type="excluded"] { background: var(--accent-red, #ef4444); }
    .tag-pill[data-type="oil"] { background: var(--accent-orange, #f59e0b); }
    .tag-pill[data-type="grain"] { background: var(--accent-green, #22c55e); }
    .tag-pill .tag-remove {
        cursor: pointer;
        opacity: 0.7;
        font-size: 0.75rem;
        transition: opacity 0.15s;
    }
    .tag-pill .tag-remove:hover { opacity: 1; }
    .tag-input {
        border: none;
        outline: none;
        background: transparent;
        color: var(--text);
        font-size: 0.85rem;
        min-width: 140px;
        flex: 1;
        padding: 0.2rem;
    }
    @@keyframes tagPop {
        0% { transform: scale(0.8); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
</style>
<script>
    function handleInBodyFileChange(input) {
        const label = document.querySelector('.inbody-file-label');
        const nameSpan = document.getElementById('inBodyFileName');
        const btn = document.getElementById('inBodySubmitBtn');
        if (input.files && input.files.length > 0) {
            nameSpan.textContent = input.files[0].name;
            label.classList.add('has-file');
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';
        } else {
            nameSpan.textContent = 'Choose a scan image…';
            label.classList.remove('has-file');
            btn.disabled = true;
            btn.style.opacity = '0.45';
            btn.style.pointerEvents = 'none';
        }
    }

    function initTagInput(inputId, hiddenId, pillsId, type) {
        const input = document.getElementById(inputId);
        const hidden = document.getElementById(hiddenId);
        const pills = document.getElementById(pillsId);

        function getTags() {
            return hidden.value ? hidden.value.split(',').map(t => t.trim()).filter(t => t) : [];
        }
        function setTags(tags) {
            hidden.value = tags.join(',');
        }
        function renderPills() {
            pills.innerHTML = '';
            getTags().forEach(tag => {
                const pill = document.createElement('span');
                pill.className = 'tag-pill';
                pill.setAttribute('data-type', type);
                pill.innerHTML = tag + ' <span class="tag-remove" title="Remove"><i class="fa-solid fa-xmark"></i></span>';
                pill.querySelector('.tag-remove').addEventListener('click', () => {
                    const tags = getTags().filter(t => t !== tag);
                    setTags(tags);
                    renderPills();
                });
                pills.appendChild(pill);
            });
        }
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ',') {
                e.preventDefault();
                const val = input.value.trim().replace(/,/g, '');
                if (val && !getTags().includes(val.toLowerCase())) {
                    const tags = getTags();
                    tags.push(val.toLowerCase());
                    setTags(tags);
                    renderPills();
                }
                input.value = '';
            }
            if (e.key === 'Backspace' && !input.value) {
                const tags = getTags();
                if (tags.length) {
                    tags.pop();
                    setTags(tags);
                    renderPills();
                }
            }
        });
        input.closest('.tag-input-wrapper').addEventListener('click', () => input.focus());
        renderPills();
    }

    document.addEventListener('DOMContentLoaded', () => {
        initTagInput('excludedFoodsInput', 'excludedFoodsHidden', 'excludedFoodsPills', 'excluded');
        initTagInput('cookingOilsInput', 'cookingOilsHidden', 'cookingOilsPills', 'oil');
        initTagInput('stapleGrainsInput', 'stapleGrainsHidden', 'stapleGrainsPills', 'grain');
    });
</script>
}
