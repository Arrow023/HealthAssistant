@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="page-header fade-up">
    <h1 class="page-title">My Profile</h1>
    <p class="page-subtitle">Manage your personal info, preferences, and workout schedule.</p>
</div>

<form method="post" asp-controller="Profile" asp-action="UpdatePreferences">
    <input type="hidden" name="userId" value="@Model.UserId" />

    <div class="grid-2 fade-up" style="align-items: start;">
        <!-- Left Column -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <!-- Personal Info -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-user" style="color: var(--primary); margin-right: 0.5rem;"></i>Personal Information</h3>
                <div class="grid-2" style="gap: 1rem;">
                    <div class="form-group">
                        <label class="form-label">First Name</label>
                        <input type="text" name="firstName" value="@Model.Profile?.FirstName" class="form-control" placeholder="First name" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last Name</label>
                        <input type="text" name="lastName" value="@Model.Profile?.LastName" class="form-control" placeholder="Last name" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" value="@Model.Profile?.Email" class="form-control" placeholder="you@example.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">New Password <span style="color: var(--text-secondary); font-weight: 400;">(leave blank to keep current)</span></label>
                    <input type="password" name="newPassword" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                </div>
            </div>

            <!-- Preferences -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-sliders" style="color: var(--accent-orange); margin-right: 0.5rem;"></i>AI Preferences</h3>
                <div class="form-group">
                    <label class="form-label">Health Conditions / Injuries</label>
                    <textarea name="preferences" rows="3" class="form-control" placeholder="e.g. Recovering from knee surgery…">@Model.Profile?.Preferences</textarea>
                    <small style="color: var(--text-secondary);">This is sent to the AI when generating your personalised workout plans.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Food Preferences / Restrictions</label>
                    <textarea name="foodPreferences" rows="3" class="form-control" placeholder="e.g. Vegetarian, no shellfish…">@Model.Profile?.FoodPreferences</textarea>
                    <small style="color: var(--text-secondary);">Used by the AI to personalise your diet plans.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Notification Time</label>
                    <input type="time" name="notificationTime" value="@Model.Profile?.NotificationTime" class="form-control" style="max-width: 200px;" />
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <!-- Weekly Schedule -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-calendar-week" style="color: var(--accent-green); margin-right: 0.5rem;"></i>Weekly Schedule</h3>
                <p style="color: var(--text-secondary); margin: 0 0 1rem; font-size: 0.9rem;">Define the focus area for each day. The AI will generate workout plans based on this schedule.</p>

                @{
                    string[] days = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
                    string[] icons = { "fa-dumbbell", "fa-heart-pulse", "fa-person-running", "fa-fire", "fa-spa", "fa-bolt", "fa-bed" };
                }
                @for (int i = 0; i < days.Length; i++)
                {
                    var day = days[i];
                    var current = Model.Profile?.WorkoutSchedule.GetValueOrDefault(day, "Rest Day") ?? "Rest Day";
                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                        <i class="fa-solid @icons[i]" style="width: 20px; text-align: center; color: var(--primary); font-size: 0.9rem;"></i>
                        <span style="width: 90px; font-weight: 600; font-size: 0.9rem;">@day</span>
                        <input type="text" name="schedule@(day)" value="@current" class="form-control" style="flex: 1;" />
                    </div>
                }
            </div>

            <!-- Webhook Config -->
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-link" style="color: var(--accent-purple); margin-right: 0.5rem;"></i>Webhook Integration</h3>
                <div class="form-group">
                    <label class="form-label">Webhook URL</label>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" id="webhookUrl" value="@Model.WebhookUrl" class="form-control" readonly style="flex: 1; font-family: monospace; font-size: 0.85rem;" />
                        <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('webhookUrl').value)" class="btn btn-outline btn-sm" title="Copy">
                            <i class="fa-solid fa-copy"></i>
                        </button>
                    </div>
                    <small style="color: var(--text-secondary);">Use this URL in automation tools (e.g. Health Connect, Tasker) to trigger workout generation.</small>
                </div>
                <div class="grid-2" style="gap: 1rem;">
                    <div class="form-group">
                        <label class="form-label">Auth Header Key</label>
                        <input type="text" name="webhookHeaderKey" value="@Model.Profile?.WebhookHeaderKey" class="form-control" placeholder="X-Api-Key" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Auth Header Value</label>
                        <input type="password" name="webhookHeaderValue" value="@Model.Profile?.WebhookHeaderValue" class="form-control" placeholder="Secret value" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end;" class="fade-up">
        <button type="submit" class="btn">
            <i class="fa-solid fa-check"></i> Save Changes
        </button>
    </div>
</form>

<!-- InBody Upload – separate form for file upload -->
<div class="card fade-up" style="margin-top: 1.5rem;">
    <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-camera" style="color: var(--accent-pink); margin-right: 0.5rem;"></i>InBody Scan Upload</h3>
    <p style="color: var(--text-secondary); margin: 0 0 1rem; font-size: 0.9rem;">Upload an InBody scan image. Our AI will extract your body composition metrics automatically using OCR.</p>
    <form method="post" asp-controller="Profile" asp-action="UploadInBody" enctype="multipart/form-data">
        <input type="hidden" name="userId" value="@Model.UserId" />
        <div style="display: flex; gap: 0.75rem; align-items: flex-end; flex-wrap: wrap;">
            <div class="form-group" style="flex: 1; min-width: 250px; margin: 0;">
                <input type="file" name="inBodyImage" accept="image/*" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-outline">
                <i class="fa-solid fa-upload"></i> Analyse Scan
            </button>
        </div>
    </form>
</div>
