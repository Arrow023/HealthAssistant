@using FitnessAgentsWeb.Core.Configuration
@model IAppConfigurationManager
@{
    ViewData["Title"] = "Global Configuration";
}

<div class="page-header fade-up">
    <h1 class="page-title">Global Configuration</h1>
    <p class="page-subtitle">Manage AI models, API keys, and notification systems for the application.</p>
</div>

<form method="post" asp-controller="Admin" asp-action="UpdateSettings">
    <div class="grid-2 fade-up" style="align-items: start;">
        <!-- AI Orchestration -->
        <div class="card">
            <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-brain" style="color: var(--primary); margin-right: 0.5rem;"></i>AI Orchestration</h3>
            <div class="form-group">
                <label class="form-label">Model ID</label>
                <input type="text" name="aiModel" value="@Model.GetAiModel()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Endpoint URL</label>
                <input type="text" name="aiEndpoint" value="@Model.GetAiEndpoint()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">API Key</label>
                <input type="password" name="aiKey" value="@Model.GetAiKey()" class="form-control" required />
            </div>
        </div>

        <!-- OCR Vision -->
        <div class="card">
            <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-eye" style="color: var(--accent-purple); margin-right: 0.5rem;"></i>OCR Vision (InBody)</h3>
            <div class="form-group">
                <label class="form-label">OCR Model ID</label>
                <input type="text" name="ocrModel" value="@Model.GetOcrModel()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">OCR Endpoint</label>
                <input type="text" name="ocrEndpoint" value="@Model.GetOcrEndpoint()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">OCR API Key</label>
                <input type="password" name="ocrKey" value="@Model.GetOcrKey()" class="form-control" required />
            </div>
        </div>

        <!-- SMTP -->
        <div class="card">
            <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-envelope" style="color: var(--accent-orange); margin-right: 0.5rem;"></i>SMTP Email Delivery</h3>
            <div class="form-group">
                <label class="form-label">SMTP Host</label>
                <input type="text" name="smtpHost" value="@Model.GetSmtpHost()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">SMTP Port</label>
                <input type="text" name="smtpPort" value="@Model.GetSmtpPort()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Sender Email</label>
                <input type="email" name="fromEmail" value="@Model.GetFromEmail()" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">App Password</label>
                <input type="password" name="smtpPassword" value="@Model.GetSmtpPassword()" class="form-control" required />
            </div>
        </div>

        <!-- Regional + Admin -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-globe" style="color: var(--accent-green); margin-right: 0.5rem;"></i>Regional Settings</h3>
                <div class="form-group">
                    <label class="form-label">Timezone</label>
                    <select name="timezone" class="form-control">
                        @foreach (var tz in FitnessAgentsWeb.Core.Helpers.TimezoneHelper.GetAllTimezones())
                        {
                            <option value="@tz" selected="@(tz == Model.GetAppTimezone())">@tz</option>
                        }
                    </select>
                </div>
            </div>

            <div class="card">
                <h3 style="margin: 0 0 1rem; font-weight: 700;"><i class="fa-solid fa-shield-halved" style="color: var(--accent-red); margin-right: 0.5rem;"></i>Admin Access</h3>
                <div class="form-group">
                    <label class="form-label">Admin Email</label>
                    <input type="email" name="adminEmail" value="@Model.GetAdminEmail()" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Admin Password</label>
                    <input type="password" name="adminPassword" value="@Model.GetAdminPassword()" class="form-control" required />
                </div>
                <small style="color: var(--accent-red); font-weight: 600;">Changing these will update your login credentials immediately.</small>
            </div>
        </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end;">
        <button type="submit" class="btn">
            <i class="fa-solid fa-cloud-arrow-up"></i> Save Configuration
        </button>
    </div>
</form>
