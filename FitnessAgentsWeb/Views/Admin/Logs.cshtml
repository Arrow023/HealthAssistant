@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Application Logs";
}

<div class="page-header fade-up">
    <h1 class="page-title">Application Logs</h1>
    <p class="page-subtitle">View recent log files for debugging and monitoring.</p>
</div>

<div class="card fade-up">
    @if (((IEnumerable<dynamic>)Model).Any())
    {
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            @foreach (var f in Model)
            {
                <a href="@Url.Action("LogFile", "Admin", new { name = f.Name })" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: var(--radius); background: var(--bg); border: 1px solid var(--border); text-decoration: none; color: var(--text); transition: border-color 0.2s;">
                    <i class="fa-solid fa-file-lines" style="color: var(--primary);"></i>
                    <span style="font-family: monospace; font-size: 0.9rem;">@f.Name</span>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-file-circle-xmark"></i>
            <p>No log files found.</p>
        </div>
    }
</div>