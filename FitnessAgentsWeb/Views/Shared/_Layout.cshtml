<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitnessAgents</title>
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Restore theme before render to prevent flash
        (function() {
            var t = localStorage.getItem('fitnessagents-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>
<body>
    @{
        var activeNav = ViewData["ActiveNav"]?.ToString() ?? "overview";
        var isAuthPage = ViewData["AuthPage"] != null;
    }

    @if (isAuthPage)
    {
        @RenderBody()
    }
    else
    {
    <div class="app-shell" id="appShell">
        <!-- Animated Background Canvas -->
        <div class="bg-canvas" aria-hidden="true">
            <div class="bg-orb bg-orb--1"></div>
            <div class="bg-orb bg-orb--2"></div>
            <div class="bg-orb bg-orb--3"></div>
            <div class="bg-orb bg-orb--4"></div>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <a href="/" class="sidebar-brand">
                <div class="sidebar-brand-icon">
                    <img src="~/images/favicon-light.svg" alt="FitnessAgents" class="show-light" style="width: 100%; height: 100%; border-radius: inherit;" />
                    <img src="~/images/favicon-dark.svg" alt="FitnessAgents" class="show-dark" style="width: 100%; height: 100%; border-radius: inherit;" />
                </div>
                <span class="sidebar-brand-text">FitnessAgents</span>
            </a>

            <nav class="sidebar-nav">
                <div class="sidebar-nav-label">Main</div>
                <a href="/" class="nav-link @(activeNav == "overview" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-chart-pie"></i></span>
                    <span>Overview</span>
                </a>
                <a href="/Workout" class="nav-link @(activeNav == "workout" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-dumbbell"></i></span>
                    <span>Workout</span>
                </a>
                <a href="/Exercise" class="nav-link @(activeNav == "exercise" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-person-running"></i></span>
                    <span>Exercise</span>
                </a>
                <a href="/Sleep" class="nav-link @(activeNav == "sleep" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-moon"></i></span>
                    <span>Sleep</span>
                </a>
                <a href="/Diet" class="nav-link @(activeNav == "diet" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-utensils"></i></span>
                    <span>Diet Plan</span>
                </a>
                <a href="/Diary" class="nav-link @(activeNav == "diary" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-book-open"></i></span>
                    <span>Diary</span>
                </a>
                <a href="/Profile" class="nav-link @(activeNav == "profile" ? "active" : "")">
                    <span class="nav-link-icon"><i class="fa-solid fa-user"></i></span>
                    <span>Profile</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-nav-label">Administration</div>
                    <a href="/Admin/Users" class="nav-link @(activeNav == "users" ? "active" : "")">
                        <span class="nav-link-icon"><i class="fa-solid fa-user-group"></i></span>
                        <span>Users</span>
                    </a>
                    <a href="/Admin/Jobs" class="nav-link @(activeNav == "jobs" ? "active" : "")">
                        <span class="nav-link-icon"><i class="fa-solid fa-bolt"></i></span>
                        <span>Jobs</span>
                    </a>
                    <a href="/Admin/Settings" class="nav-link @(activeNav == "settings" ? "active" : "")">
                        <span class="nav-link-icon"><i class="fa-solid fa-gear"></i></span>
                        <span>Settings</span>
                    </a>
                    <a href="/Admin/Logs" class="nav-link @(activeNav == "logs" ? "active" : "")">
                        <span class="nav-link-icon"><i class="fa-solid fa-terminal"></i></span>
                        <span>Logs</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer">
                @if (User.Identity is not null && User.Identity.IsAuthenticated)
                {
                    <div class="sidebar-user">
                        <div class="sidebar-user-avatar">
                            @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <div class="sidebar-user-info">
                            <span class="sidebar-user-name">@User.Identity.Name</span>
                            <span class="sidebar-user-role">@(User.IsInRole("Admin") ? "Administrator" : "Member")</span>
                        </div>
                    </div>
                    <form method="post" action="/Auth/Logout">
                        <button type="submit" class="nav-link logout-btn">
                            <span class="nav-link-icon"><i class="fa-solid fa-arrow-right-from-bracket"></i></span>
                            <span>Logout</span>
                        </button>
                    </form>
                }
            </div>
        </aside>

        <button class="sidebar-toggle" onclick="toggleSidebar()" title="Toggle sidebar">
            <i class="fa-solid fa-chevron-left"></i>
        </button>

        <!-- Main Area -->
        <div class="main-area" id="mainArea">
            <header class="topbar">
                <button class="topbar-btn" style="display:none;" id="mobileMenuBtn" onclick="document.getElementById('sidebar').classList.toggle('mobile-open')">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="topbar-search">
                    <i class="fa-solid fa-magnifying-glass" style="font-size: 0.85rem;"></i>
                    <input type="text" placeholder="Search..." disabled />
                </div>
                <div class="topbar-actions">
                    <button class="topbar-btn" onclick="toggleTheme()" title="Toggle theme" id="themeToggleBtn">
                        <i class="fa-solid fa-sun"></i>
                    </button>
                    <div class="notif-wrapper" id="notifWrapper">
                        <button class="topbar-btn" title="Notifications" id="notifBellBtn" onclick="toggleNotifPanel()">
                            <i class="fa-solid fa-bell"></i>
                            <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
                        </button>
                        <div class="notif-panel" id="notifPanel">
                            <div class="notif-panel-header">
                                <span class="notif-panel-title">Notifications</span>
                                <button class="notif-mark-all" id="notifMarkAll" onclick="markAllRead()">Mark all read</button>
                            </div>
                            <div class="notif-panel-body" id="notifList">
                                <div class="notif-empty">No notifications yet</div>
                            </div>
                        </div>
                    </div>
                    @if (User.Identity is not null && User.Identity.IsAuthenticated)
                    {
                        <div class="topbar-avatar">@(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")</div>
                    }
                </div>
            </header>

            <div class="page-content">
                @RenderBody()
            </div>
        </div>
    </div>
    }

    <script>
        function toggleTheme() {
            var html = document.documentElement;
            var current = html.getAttribute('data-theme');
            var next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('fitnessagents-theme', next);
            updateThemeIcon(next);
        }

        function updateThemeIcon(theme) {
            var btn = document.getElementById('themeToggleBtn');
            if (!btn) return;
            var icon = theme === 'dark'
                ? '<i class="fa-solid fa-sun" style="transition: transform 0.3s; color: #fbbf24;"></i>'
                : '<i class="fa-solid fa-moon" style="transition: transform 0.3s; color: #6366f1;"></i>';
            btn.style.transition = 'transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)';
            btn.style.transform = 'rotate(180deg) scale(0.8)';
            setTimeout(function() {
                btn.innerHTML = icon;
                btn.style.transform = 'rotate(0deg) scale(1)';
            }, 150);
        }

        function toggleSidebar() {
            document.getElementById('appShell')?.classList.toggle('sidebar-collapsed');
            var collapsed = document.getElementById('appShell')?.classList.contains('sidebar-collapsed');
            localStorage.setItem('fitnessagents-sidebar', collapsed ? 'collapsed' : 'expanded');
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Restore sidebar state
            if (localStorage.getItem('fitnessagents-sidebar') === 'collapsed') {
                document.getElementById('appShell')?.classList.add('sidebar-collapsed');
            }
            // Set theme icon
            updateThemeIcon(document.documentElement.getAttribute('data-theme') || 'dark');

            // Mobile menu visibility
            if (window.innerWidth <= 768) {
                var mb = document.getElementById('mobileMenuBtn');
                if (mb) mb.style.display = 'flex';
            }
        });
    </script>
    @if (IsSectionDefined("Scripts"))
    {
        @RenderSection("Scripts", required: false)
    }

    @if (User.Identity is not null && User.Identity.IsAuthenticated)
    {
    <script>
        // ── Notification System ──
        (function() {
            var panel = document.getElementById('notifPanel');
            var badge = document.getElementById('notifBadge');
            var list  = document.getElementById('notifList');
            var isOpen = false;

            // Close panel on outside click
            document.addEventListener('click', function(e) {
                var wrapper = document.getElementById('notifWrapper');
                if (wrapper && !wrapper.contains(e.target) && isOpen) {
                    panel.classList.remove('open');
                    isOpen = false;
                }
            });

            // Toggle panel
            window.toggleNotifPanel = function() {
                isOpen = !isOpen;
                panel.classList.toggle('open', isOpen);
                if (isOpen) loadNotifications();
            };

            // Load notifications from API
            window.loadNotifications = function() {
                fetch('/api/notifications')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        renderList(data.notifications || []);
                        updateBadge(data.unreadCount || 0);
                    })
                    .catch(function() {});
            };

            // Mark all read
            window.markAllRead = function() {
                fetch('/api/notifications/read-all', { method: 'POST' })
                    .then(function() {
                        updateBadge(0);
                        document.querySelectorAll('.notif-item.unread').forEach(function(el) {
                            el.classList.remove('unread');
                        });
                    });
            };

            function updateBadge(count) {
                if (count > 0) {
                    badge.textContent = count > 9 ? '9+' : count;
                    badge.style.display = '';
                } else {
                    badge.style.display = 'none';
                }
            }

            function renderList(items) {
                if (!items.length) {
                    list.innerHTML = '<div class="notif-empty">No notifications yet</div>';
                    return;
                }
                var html = '';
                items.forEach(function(n) {
                    var cls = n.isRead ? 'notif-item' : 'notif-item unread';
                    var icon = n.icon || 'fa-solid fa-bell';
                    var ago = timeAgo(n.createdAt);
                    var link = n.link || '#';
                    html += '<a href="' + link + '" class="' + cls + '" data-id="' + n.id + '" onclick="markItemRead(\'' + n.id + '\')">'
                         + '<div class="notif-item-icon"><i class="' + icon + '"></i></div>'
                         + '<div class="notif-item-body">'
                         + '<div class="notif-item-title">' + escapeHtml(n.title) + '</div>'
                         + '<div class="notif-item-msg">' + escapeHtml(n.message) + '</div>'
                         + '<div class="notif-item-time">' + ago + '</div>'
                         + '</div></a>';
                });
                list.innerHTML = html;
            }

            // Add single notification to top of list
            function prependNotification(n) {
                var existing = list.querySelector('.notif-empty');
                if (existing) existing.remove();

                var icon = n.icon || 'fa-solid fa-bell';
                var ago = timeAgo(n.createdAt);
                var link = n.link || '#';
                var el = document.createElement('a');
                el.href = link;
                el.className = 'notif-item unread notif-slide-in';
                el.setAttribute('data-id', n.id);
                el.onclick = function() { markItemRead(n.id); };
                el.innerHTML = '<div class="notif-item-icon"><i class="' + icon + '"></i></div>'
                    + '<div class="notif-item-body">'
                    + '<div class="notif-item-title">' + escapeHtml(n.title) + '</div>'
                    + '<div class="notif-item-msg">' + escapeHtml(n.message) + '</div>'
                    + '<div class="notif-item-time">' + ago + '</div>'
                    + '</div>';
                list.prepend(el);
            }

            window.markItemRead = function(id) {
                fetch('/api/notifications/' + id + '/read', { method: 'POST' });
                var el = list.querySelector('[data-id="' + id + '"]');
                if (el) el.classList.remove('unread');
            };

            function timeAgo(iso) {
                var diff = (Date.now() - new Date(iso).getTime()) / 1000;
                if (diff < 60) return 'just now';
                if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
                if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
                return Math.floor(diff / 86400) + 'd ago';
            }

            function escapeHtml(s) {
                var d = document.createElement('div');
                d.textContent = s || '';
                return d.innerHTML;
            }

            // ── SSE connection for real-time push ──
            if (typeof EventSource !== 'undefined') {
                var evtSource = new EventSource('/api/notifications/stream');

                evtSource.addEventListener('notification', function(e) {
                    var n = JSON.parse(e.data);
                    prependNotification(n);

                    // Show a brief toast
                    showNotifToast(n);
                });

                evtSource.addEventListener('unread', function(e) {
                    var data = JSON.parse(e.data);
                    updateBadge(data.count);
                });

                evtSource.onerror = function() {
                    // Reconnect is automatic with EventSource
                };
            }

            function showNotifToast(n) {
                var container = document.getElementById('globalToastContainer');
                if (!container) {
                    container = document.createElement('div');
                    container.id = 'globalToastContainer';
                    container.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:1100;display:flex;flex-direction:column;gap:0.5rem;';
                    document.body.appendChild(container);
                }
                var toast = document.createElement('div');
                toast.className = 'notif-toast';
                var icon = n.icon || 'fa-solid fa-bell';
                toast.innerHTML = '<i class="' + icon + '"></i> <strong>' + escapeHtml(n.title) + '</strong> — ' + escapeHtml(n.message);
                container.appendChild(toast);
                setTimeout(function() {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(20px)';
                    setTimeout(function() { toast.remove(); }, 300);
                }, 4000);
            }

            // Load initial count on page ready
            loadNotifications();
        })();
    </script>
    }
</body>
</html>
